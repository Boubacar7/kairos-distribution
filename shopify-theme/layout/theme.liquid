<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_bordeaux }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{%- endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{%- endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{%- endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <style>
      :root {
        --bordeaux:     {{ settings.color_bordeaux      | default: '#6d1e3a' }};
        --bordeaux-dk:  {{ settings.color_bordeaux_dark | default: '#521529' }};
        --rose-50:      {{ settings.color_rose_50       | default: '#fbe8e3' }};
        --rose-100:     {{ settings.color_rose_100      | default: '#f5d9d3' }};
        --rose-200:     {{ settings.color_rose_200      | default: '#edc5bd' }};
        --cream:        {{ settings.color_cream         | default: '#fbf4ef' }};
        --cream-2:      {{ settings.color_cream_2       | default: '#f6ebe3' }};
        --ink:          {{ settings.color_ink           | default: '#1a1414' }};
        --ink-2:        {{ settings.color_ink_2         | default: '#3b2e2e' }};
        --muted:        {{ settings.color_muted         | default: '#7a6a6a' }};
        --r-sm: {{ settings.radius_sm | default: 12 }}px;
        --r-md: {{ settings.radius_md | default: 18 }}px;
        --r-lg: {{ settings.radius_lg | default: 28 }}px;
        --body-size:    {{ settings.type_base_size       | default: 15 }}px;
        --body-weight:  {{ settings.type_body_weight     | default: 400 }};
        --display-weight:{{ settings.type_display_weight | default: 400 }};
        --card-ratio:   {{ settings.card_image_ratio     | default: '3/4' }};
        --card-fit:     {{ settings.card_image_fit       | default: 'cover' }};
        --section-pad-desktop: {{ settings.section_pad_desktop | default: 72 }}px;
        --section-pad-mobile:  {{ settings.section_pad_mobile  | default: 48 }}px;
        --container-max: {{ settings.container_max_width | default: 1280 }}px;
      }
      body { font-size: var(--body-size); font-weight: var(--body-weight); }
      .display, h1, h2, h3, h4 { font-weight: var(--display-weight); }
      .container { max-width: var(--container-max); }
      .section-pad { padding-top: var(--section-pad-desktop); padding-bottom: var(--section-pad-desktop); }
      @media (max-width: 720px) {
        .section-pad { padding-top: var(--section-pad-mobile); padding-bottom: var(--section-pad-mobile); }
      }
      .product-card .media { aspect-ratio: var(--card-ratio); }
      .product-card .media img { object-fit: var(--card-fit); }
      {%- if settings.card_hover_lift == false -%}
        .product-card:hover { transform: none; box-shadow: none; }
      {%- endif -%}
    </style>

    {{ content_for_header }}
  </head>
  <body class="template-{{ template | split: '.' | first }}">
    <a class="sr-only" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
