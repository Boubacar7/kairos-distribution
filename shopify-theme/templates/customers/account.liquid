<section class="container" style="padding:90px 0 60px;max-width:900px;">
  <span class="kicker">Mon compte</span>
  <h1 class="display" style="font-size:clamp(28px,4vw,40px);margin:8px 0 4px;">Bienvenue, {{ customer.first_name | default: customer.email }}</h1>
  <p style="color:var(--muted);font-size:14px;margin:0 0 24px;">
    <a href="{{ routes.account_addresses_url }}">Mes adresses</a> ·
    <a href="{{ routes.account_logout_url }}">Se déconnecter</a>
  </p>

  <h2 class="display" style="font-size:22px;margin:24px 0 12px;">Mes commandes</h2>
  {%- if customer.orders.size == 0 -%}
    <p style="color:var(--muted);font-size:14px;">Aucune commande pour le moment.</p>
  {%- else -%}
    <table style="width:100%;border-collapse:collapse;font-size:14px;">
      <thead>
        <tr style="border-bottom:1px solid var(--line);text-align:left;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.08em;">
          <th style="padding:8px 0;">Commande</th><th>Date</th><th>Total</th><th>Statut</th>
        </tr>
      </thead>
      <tbody>
      {%- for o in customer.orders -%}
        <tr style="border-bottom:1px solid var(--line);">
          <td style="padding:10px 0;"><a href="{{ o.customer_url }}">{{ o.name }}</a></td>
          <td>{{ o.created_at | date: '%d %b %Y' }}</td>
          <td>{{ o.total_price | money }}</td>
          <td>{{ o.fulfillment_status_label | default: o.financial_status_label }}</td>
        </tr>
      {%- endfor -%}
      </tbody>
    </table>
  {%- endif -%}
</section>
