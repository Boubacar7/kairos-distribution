<section class="container" style="padding:90px 0 60px;max-width:460px;">
  <span class="kicker">Compte</span>
  <h1 class="display" style="font-size:clamp(28px,4vw,36px);margin:8px 0 24px;">Créer un compte</h1>
  {%- form 'create_customer', novalidate: 'novalidate' -%}
    {%- if form.errors -%}
      <div style="background:#fff3f3;color:#b22;padding:10px;border-radius:var(--r-sm);font-size:13px;margin-bottom:12px;">{{ form.errors | default_errors }}</div>
    {%- endif -%}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
      <input type="text" name="customer[first_name]" placeholder="Prénom" required style="padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);">
      <input type="text" name="customer[last_name]"  placeholder="Nom"    required style="padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);">
    </div>
    <input type="email"    name="customer[email]"    placeholder="Email"          required style="width:100%;padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);margin-bottom:12px;">
    <input type="password" name="customer[password]" placeholder="Mot de passe"  required style="width:100%;padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);margin-bottom:14px;">
    <button type="submit" class="btn btn-p" style="width:100%;">S'inscrire</button>
    <p style="margin-top:16px;font-size:13px;text-align:center;color:var(--muted);">Déjà inscrit ? <a href="{{ routes.account_login_url }}">Se connecter</a></p>
  {%- endform -%}
</section>
