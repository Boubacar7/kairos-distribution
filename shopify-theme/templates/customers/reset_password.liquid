<section class="container" style="padding:90px 0 60px;max-width:420px;">
  <span class="kicker">Compte</span>
  <h1 class="display" style="font-size:clamp(28px,4vw,36px);margin:8px 0 24px;">Réinitialiser le mot de passe</h1>
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}<div style="background:#fff3f3;color:#b22;padding:10px;border-radius:var(--r-sm);font-size:13px;margin-bottom:12px;">{{ form.errors | default_errors }}</div>{%- endif -%}
    <input type="password" name="customer[password]"              placeholder="Nouveau mot de passe"   required style="width:100%;padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);margin-bottom:12px;">
    <input type="password" name="customer[password_confirmation]" placeholder="Confirmer mot de passe" required style="width:100%;padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);margin-bottom:14px;">
    <button type="submit" class="btn btn-p" style="width:100%;">Valider</button>
  {%- endform -%}
</section>
