<section class="container" style="padding:90px 0 60px;max-width:420px;">
  <span class="kicker">Compte</span>
  <h1 class="display" style="font-size:clamp(28px,4vw,36px);margin:8px 0 24px;">Connexion</h1>

  {%- form 'customer_login', novalidate: 'novalidate' -%}
    {%- if form.errors -%}
      <div style="background:#fff3f3;color:#b22;padding:10px;border-radius:var(--r-sm);font-size:13px;margin-bottom:12px;">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}
    <label style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);">Email</label>
    <input type="email" name="customer[email]" required style="width:100%;padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);margin:4px 0 14px;">
    <label style="font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);">Mot de passe</label>
    <input type="password" name="customer[password]" required style="width:100%;padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-sm);margin:4px 0 14px;">
    <button type="submit" class="btn btn-p" style="width:100%;">Se connecter</button>
    <p style="margin-top:16px;font-size:13px;color:var(--muted);text-align:center;">
      <a href="{{ routes.account_recover_url }}">Mot de passe oublié ?</a> ·
      <a href="{{ routes.account_register_url }}">Créer un compte</a>
    </p>
  {%- endform -%}
</section>
