<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(150deg,#521529 0%,#6d1e3a 45%,#8a2d4d 75%,#e8c4bc 100%);padding:24px;">
  <div style="background:#fff;border-radius:var(--r-lg);padding:48px;max-width:460px;width:100%;text-align:center;box-shadow:var(--sh-lg);">
    <h1 class="display" style="font-size:36px;letter-spacing:-.02em;margin:0 0 8px;">{{ shop.name }}</h1>
    <p style="color:var(--muted);margin:0 0 28px;">{{ shop.password_message | default: 'Boutique bientôt ouverte.' }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <div style="background:#fff3f3;color:#b22;padding:10px;border-radius:var(--r-sm);font-size:13px;margin-bottom:12px;">
          Mot de passe incorrect.
        </div>
      {%- endif -%}
      <input type="password" name="password" placeholder="Mot de passe"
             class="input" style="padding:12px 16px;border:1px solid var(--line-2);border-radius:var(--r-pill);font-size:14px;width:100%;margin-bottom:12px;">
      <button type="submit" class="btn btn-p" style="width:100%;">Entrer</button>
    {%- endform -%}
  </div>
</div>
