{%- comment -%}
  Cart drawer Kairos — slide-in sur la droite. Mis à jour via fetch sur
  /cart.js et /cart/change.js. Toutes les sections doivent ajouter
  `data-add-to-cart` sur les boutons d'ajout pour bénéficier du drawer.
{%- endcomment -%}
<div class="cart-drawer" data-cart-drawer hidden aria-hidden="true">
  <div class="cart-backdrop" data-cart-close></div>
  <aside class="cart-dialog" role="dialog" aria-modal="true" aria-label="Panier">
    <header class="cart-head">
      <div>
        <span class="kicker">Panier</span>
        <div class="display cart-count-title" style="font-size:24px;margin-top:4px;">
          <span data-cart-count>0</span> article(s)
        </div>
      </div>
      <button type="button" class="cart-close" data-cart-close aria-label="Fermer">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </header>
    <div class="cart-body" data-cart-items>
      <div class="cart-empty" data-cart-empty>
        <div class="cart-empty-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2l2.5 12h11L21 7H6"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg>
        </div>
        <div class="display" style="font-size:18px;">Panier vide</div>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-p btn-sm" style="margin-top:12px;">Voir la boutique</a>
      </div>
    </div>
    <footer class="cart-foot" data-cart-foot hidden>
      <div class="cart-row"><span>Sous-total</span><strong data-cart-subtotal>0</strong></div>
      <p class="cart-note">Livraison calculée au checkout.</p>
      <a href="/checkout" class="btn btn-p" style="width:100%;margin-top:8px;">Passer commande →</a>
    </footer>
  </aside>
</div>

<style>
  .cart-drawer[hidden] { display: none; }
  .cart-drawer { position: fixed; inset: 0; z-index: 600; }
  .cart-backdrop { position: absolute; inset: 0; background: rgba(26,20,20,.5); backdrop-filter: blur(4px); cursor: pointer; }
  .cart-dialog {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(440px, 100vw);
    background: var(--cream);
    display: flex; flex-direction: column;
    animation: cart-slide .25s cubic-bezier(.2,.8,.2,1);
    box-shadow: -20px 0 60px rgba(0,0,0,.18);
  }
  @keyframes cart-slide { from { transform: translateX(100%); } to { transform: translateX(0); } }
  .cart-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 24px 16px;
    border-bottom: 1px solid var(--line);
  }
  .cart-close {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--cream-2); color: var(--ink);
    display: flex; align-items: center; justify-content: center; cursor: pointer;
  }
  .cart-body { flex: 1; overflow-y: auto; padding: 8px 24px; }
  .cart-empty { text-align: center; padding: 60px 0; color: var(--muted); }
  .cart-empty-icon {
    width: 64px; height: 64px; margin: 0 auto 14px;
    border-radius: 50%; background: var(--rose-100); color: var(--bordeaux);
    display: flex; align-items: center; justify-content: center;
  }
  .cart-line {
    display: grid; grid-template-columns: 64px 1fr auto; gap: 12px;
    padding: 16px 0; border-bottom: 1px solid var(--line);
    align-items: center;
  }
  .cart-line:last-child { border-bottom: 0; }
  .cart-line img { width: 64px; height: 64px; object-fit: cover; border-radius: var(--r-sm); background: var(--rose-50); }
  .cart-line .ttl { font-size: 14px; font-weight: 500; }
  .cart-line .var { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .cart-line .price { font-size: 13px; color: var(--muted); margin-top: 2px; }
  .cart-line .qty {
    display: inline-flex; align-items: center;
    border: 1px solid var(--line-2); border-radius: var(--r-pill);
    margin-top: 6px;
  }
  .cart-line .qty button { padding: 4px 10px; cursor: pointer; }
  .cart-line .qty span { padding: 0 8px; font-size: 13px; }
  .cart-line .rm {
    color: var(--muted); font-size: 12px; cursor: pointer;
    background: none; border: 0; margin-top: 4px;
  }
  .cart-line .rm:hover { color: var(--bordeaux); }
  .cart-foot {
    padding: 16px 24px 24px;
    border-top: 1px solid var(--line);
    background: #fff;
  }
  .cart-row { display: flex; justify-content: space-between; align-items: center; font-size: 14px; }
  .cart-row strong { font-family: var(--f-display); font-size: 22px; }
  .cart-note { font-size: 11px; color: var(--muted); margin: 4px 0 0; }
  /* Toast confirmation ajout */
  .cart-toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: var(--ink); color: #fff; padding: 12px 18px;
    border-radius: var(--r-pill); font-size: 13px;
    box-shadow: var(--sh-lg); z-index: 700;
    display: flex; align-items: center; gap: 10px;
    animation: toast-in .25s; white-space: nowrap;
  }
  @keyframes toast-in { from { opacity: 0; transform: translate(-50%, 12px); } to { opacity: 1; transform: translate(-50%, 0); } }
  .cart-toast .dot { width: 8px; height: 8px; border-radius: 50%; background: #89d39a; }
</style>

<script>
  (function() {
    var drawer = document.querySelector('[data-cart-drawer]');
    if (!drawer) return;
    var itemsEl = drawer.querySelector('[data-cart-items]');
    var emptyEl = drawer.querySelector('[data-cart-empty]');
    var footEl  = drawer.querySelector('[data-cart-foot]');
    var subEl   = drawer.querySelector('[data-cart-subtotal]');
    var countEl = drawer.querySelector('[data-cart-count]');

    function moneyFormat(cents) {
      // Shopify renvoie des montants en sous-unité. Fallback simple.
      return (cents / 100).toLocaleString('fr-FR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    }

    function open()  { drawer.removeAttribute('hidden'); drawer.setAttribute('aria-hidden', 'false'); document.documentElement.style.overflow = 'hidden'; }
    function close() { drawer.setAttribute('hidden', '');  drawer.setAttribute('aria-hidden', 'true');  document.documentElement.style.overflow = ''; }

    function renderCart(cart) {
      countEl.textContent = cart.item_count || 0;
      // Met à jour aussi le badge de la nav
      document.querySelectorAll('.nav-badge').forEach(function(el) {
        el.textContent = cart.item_count;
        el.style.display = cart.item_count > 0 ? '' : 'none';
      });
      if (!cart.items || cart.items.length === 0) {
        emptyEl.style.display = '';
        footEl.setAttribute('hidden', '');
        // Vide les lignes
        Array.prototype.slice.call(itemsEl.querySelectorAll('.cart-line')).forEach(function(n) { n.remove(); });
        return;
      }
      emptyEl.style.display = 'none';
      footEl.removeAttribute('hidden');
      var html = cart.items.map(function(it) {
        var img = it.image ? '<img src="' + it.image + '" alt="">' : '<div></div>';
        var variant = (it.variant_title && it.variant_title !== 'Default Title') ? '<div class="var">' + it.variant_title + '</div>' : '';
        return [
          '<div class="cart-line" data-key="', it.key, '">',
            img,
            '<div>',
              '<div class="ttl">', it.product_title, '</div>',
              variant,
              '<div class="price">', moneyFormat(it.final_line_price), ' ', cart.currency, '</div>',
              '<div class="qty">',
                '<button data-qty="-1" aria-label="Moins">−</button>',
                '<span>', it.quantity, '</span>',
                '<button data-qty="+1" aria-label="Plus">+</button>',
              '</div>',
              '<button class="rm" data-rm>Retirer</button>',
            '</div>',
            '<div><strong>', moneyFormat(it.final_line_price), ' ', cart.currency, '</strong></div>',
          '</div>'
        ].join('');
      }).join('');
      // Reset puis insertion
      Array.prototype.slice.call(itemsEl.querySelectorAll('.cart-line')).forEach(function(n) { n.remove(); });
      itemsEl.insertAdjacentHTML('beforeend', html);
      subEl.textContent = moneyFormat(cart.total_price) + ' ' + cart.currency;
    }

    function refresh() {
      return fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(renderCart);
    }

    function changeLine(key, qty) {
      return fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty })
      }).then(function(r) { return r.json(); }).then(renderCart);
    }

    function addToCart(formData) {
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: formData
      }).then(function(r) {
        if (!r.ok) throw new Error('Add to cart failed');
        return r.json();
      }).then(function() {
        return refresh();
      }).then(function() {
        showToast('Ajouté au panier');
        open();
      });
    }

    function showToast(msg) {
      var t = document.createElement('div');
      t.className = 'cart-toast';
      t.innerHTML = '<span class="dot"></span><span>' + msg + '</span>';
      document.body.appendChild(t);
      setTimeout(function() { t.remove(); }, 1800);
    }

    // Intercepte les clics sur les liens "panier" du header pour ouvrir le drawer
    document.addEventListener('click', function(e) {
      var cartLink = e.target.closest('.nav-cart');
      if (cartLink && cartLink.getAttribute('href') && cartLink.getAttribute('href').indexOf('/cart') !== -1) {
        e.preventDefault();
        open();
        refresh();
        return;
      }
      if (e.target.closest('[data-cart-close]')) { close(); return; }
      // qty +/-
      var qtyBtn = e.target.closest('.cart-line .qty button');
      if (qtyBtn) {
        var line = qtyBtn.closest('.cart-line');
        var span = line.querySelector('.qty span');
        var current = parseInt(span.textContent, 10);
        var next = current + (qtyBtn.getAttribute('data-qty') === '-1' ? -1 : 1);
        changeLine(line.getAttribute('data-key'), Math.max(0, next));
        return;
      }
      var rmBtn = e.target.closest('.cart-line .rm');
      if (rmBtn) {
        var line2 = rmBtn.closest('.cart-line');
        changeLine(line2.getAttribute('data-key'), 0);
      }
    });

    // Intercepte les soumissions de formulaire d'ajout au panier
    document.addEventListener('submit', function(e) {
      var form = e.target;
      if (form.matches('form[action="/cart/add"], form[action$="/cart/add"]')) {
        e.preventDefault();
        addToCart(new FormData(form));
      }
    });

    // Init du compteur dès le chargement
    refresh();

    // Escape pour fermer
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !drawer.hasAttribute('hidden')) close();
    });

    // Expose
    window.kairosCart = { open: function() { open(); refresh(); }, close: close, refresh: refresh };
  })();
</script>
