{%- comment -%}
  Catalogue éditable — version simplifiée et robuste.
  Chaque produit est un block du Customizer (image, nom, catégorie,
  description, prix en FCFA, ancien prix, lien). Pas de popup ni JS
  inline : le clic sur la card va directement à l'URL renseignée.
  Conversion devise gérée par le JS du header (data-price-fcfa).
{%- endcomment -%}
<section class="section-pad" id="{{ section.settings.anchor | default: 'produits' }}" style="scroll-margin-top: 80px;">
  <div class="container">
    <div class="section-heading">
      <div style="display:flex;flex-direction:column;gap:6px;">
        {%- if section.settings.kicker != blank -%}<span class="kicker">{{ section.settings.kicker }}</span>{%- endif -%}
        <h2 class="display">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_link != blank and section.settings.view_all_label != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="btn btn-g btn-sm">
          {{ section.settings.view_all_label }} →
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="product-grid">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          {%- assign card_link = b.link | default: '#' -%}
          <a href="{{ card_link }}" class="product-card" {{ block.shopify_attributes }}>
            <div class="media">
              {%- if b.image -%}
                <img src="{{ b.image | image_url: width: 600 }}"
                     alt="{{ b.image.alt | default: b.title }}"
                     loading="lazy">
              {%- else -%}
                <div class="ph-fallback"></div>
              {%- endif -%}
            </div>
            <div class="chips">
              {%- if b.category != blank -%}
                <span class="chip">{{ b.category }}</span>
              {%- else -%}
                <span></span>
              {%- endif -%}
              {%- if b.compare_fcfa > 0 or b.compare_label != blank -%}
                <span class="chip chip-promo" style="font-size:10px;padding:4px 8px;">PROMO</span>
              {%- endif -%}
            </div>
            <div class="title">{{ b.title }}</div>
            {%- if b.description != blank -%}
              <div class="tagline">{{ b.description | truncate: 90 }}</div>
            {%- else -%}
              <div class="tagline"></div>
            {%- endif -%}
            <div class="price-row">
              <div>
                {%- if b.price_fcfa > 0 -%}
                  <span class="price" data-price-fcfa="{{ b.price_fcfa }}">{{ b.price_fcfa }} FCFA</span>
                {%- else -%}
                  <span class="price">{{ b.price_label }}</span>
                {%- endif -%}
                {%- if b.compare_fcfa > 0 -%}
                  <span class="old-price" data-compare-fcfa="{{ b.compare_fcfa }}">{{ b.compare_fcfa }} FCFA</span>
                {%- elsif b.compare_label != blank -%}
                  <span class="old-price">{{ b.compare_label }}</span>
                {%- endif -%}
              </div>
              <span class="add-btn" aria-hidden="true">→</span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="color:var(--muted);font-size:14px;">Ajoute un produit via « Ajouter un block » dans le Customizer.</p>
    {%- endif -%}
  </div>
</section>

<style>
  .ph-fallback {
    width: 100%; height: 100%;
    background: linear-gradient(135deg,#f5d9d3 0%,#e8b8c8 50%,#d6a3b8 100%);
  }
</style>

{% schema %}
{
  "name": "Catalogue éditable",
  "settings": [
    { "type": "text", "id": "anchor",  "label": "Ancre (id)", "default": "produits" },
    { "type": "text", "id": "kicker",  "label": "Kicker", "default": "Catalogue" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Nos rituels du moment" },
    { "type": "text", "id": "view_all_label", "label": "Libellé « Tout voir »", "default": "Tout voir" },
    { "type": "url",  "id": "view_all_link",  "label": "Lien « Tout voir »" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produit",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text",     "id": "title",        "label": "Nom du produit", "default": "Nom du produit" },
        { "type": "text",     "id": "category",     "label": "Catégorie (chip)", "default": "Beauté" },
        { "type": "textarea", "id": "description",  "label": "Accroche (texte court)" },

        { "type": "header", "content": "Prix (en FCFA — conversion auto EUR/USD/CAD)" },
        { "type": "number", "id": "price_fcfa",   "label": "Prix actuel (FCFA)" },
        { "type": "number", "id": "compare_fcfa", "label": "Ancien prix (FCFA, barré)" },

        { "type": "header", "content": "Alternative : prix en texte libre" },
        { "type": "text",   "id": "price_label",   "label": "Prix (texte libre)" },
        { "type": "text",   "id": "compare_label", "label": "Ancien prix (texte libre)" },

        { "type": "header", "content": "Lien" },
        { "type": "url",    "id": "link", "label": "Lien produit (URL fiche complète)" }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Catalogue éditable",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
