<section class="section-pad" id="{{ section.settings.anchor | default: 'retours' }}">
  <div class="container">
    <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:28px;">
      {%- if section.settings.kicker != blank -%}
        <span class="kicker">{{ section.settings.kicker }}</span>
      {%- endif -%}
      <h2 class="display" style="font-size:clamp(22px,3.5vw,40px);letter-spacing:-.02em;margin:0;">
        {{ section.settings.heading }}
      </h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
      {%- for block in section.blocks -%}
        {%- assign fallback_index = forloop.index0 | modulo: 4 | plus: 1 -%}
        {%- capture fallback_url -%}community-{{ fallback_index }}.jpg{%- endcapture -%}
        <div {{ block.shopify_attributes }} style="aspect-ratio:1/1;overflow:hidden;border-radius:var(--r-md);background:var(--rose-50);">
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              srcset="{{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 600 }} 600w"
              sizes="(max-width: 700px) 50vw, 25vw"
              alt="{{ block.settings.image.alt | default: 'Retour client' }}"
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;transition:transform .5s;"
              onmouseover="this.style.transform='scale(1.05)'"
              onmouseout="this.style.transform='scale(1)'">
          {%- else -%}
            {%- comment -%}Fallback sur assets/community-{1..4}.jpg cyclés.{%- endcomment -%}
            <img
              src="{{ fallback_url | asset_url }}"
              alt="Retour client {{ forloop.index }}"
              loading="lazy"
              style="width:100%;height:100%;object-fit:cover;transition:transform .5s;"
              onmouseover="this.style.transform='scale(1.05)'"
              onmouseout="this.style.transform='scale(1)'">
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  @media (max-width: 700px) {
    #{{ section.settings.anchor | default: 'retours' }} > div > div:last-child {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Retours clients",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "retours" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Retours clients" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Photos partagées par la communauté" }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo communauté" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Retours clients",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
