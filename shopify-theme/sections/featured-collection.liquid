<section class="section-pad" id="{{ section.settings.anchor | default: 'produits' }}" style="scroll-margin-top: 80px;">
  <div class="container">
    <div class="section-heading">
      <div style="display:flex;flex-direction:column;gap:6px;">
        {%- if section.settings.kicker != blank -%}<span class="kicker">{{ section.settings.kicker }}</span>{%- endif -%}
        <h2 class="display">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="btn btn-g btn-sm">
          {{ 'sections.featured_collection.view_all' | t }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- assign collection = collections[section.settings.collection] -%}
    {%- assign limit = section.settings.products_to_show | default: 4 -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <div class="product-grid">
        {%- for product in collection.products limit: limit -%}
          {% render 'card-product', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%}
        Boutique encore vide : on affiche des produits démo baked-in dans le
        thème. Dès que l'opérateur importe shopify-products.csv et associe
        une collection (ex. "frontpage"), ce bloc disparaît automatiquement.
      {%- endcomment -%}
      <div class="product-grid">
        {% render 'card-product-demo', handle: 'glow-skin',   title: 'Glow Skin Crème',      category: 'Beauté',      description: "Hydratation intense, éclat visible en 7 jours.", price_label: '24 900 FCFA', compare_label: '32 000 FCFA', image: 'glow-skin.png' %}
        {% render 'card-product-demo', handle: 'trim-active', title: 'Trim Active Plus',     category: 'Amincissant', description: 'Programme silhouette 28 jours.',                   price_label: '18 500 FCFA', image: 'trim-active.png' %}
        {% render 'card-product-demo', handle: 'curve-up',    title: 'Curve Up Gel',         category: 'Postérieur',  description: 'Routine tonifiante et raffermissante.',            price_label: '27 500 FCFA', image: 'curve-up.png' %}
        {% render 'card-product-demo', handle: 'confidence',  title: 'Confidence Kit',       category: 'Promo',       description: 'Rituel complet beauté + silhouette.',              price_label: '54 000 FCFA', compare_label: '72 000 FCFA', image: 'confidence.png' %}
        {%- if limit > 4 -%}
          {% render 'card-product-demo', handle: 'shape-mask',  title: 'Shape & Firm Masque', category: 'Postérieur',  description: 'Masque raffermissant express 20 min.',             price_label: '19 900 FCFA', image: 'shape-mask.png' %}
          {% render 'card-product-demo', handle: 'lip-glow',    title: 'Lip & Glow Set',      category: 'Promo',       description: 'Pack découverte lèvres + visage.',                 price_label: '15 900 FCFA', compare_label: '22 000 FCFA' %}
          {% render 'card-product-demo', handle: 'velvet-body', title: 'Velvet Body Milk',    category: 'Beauté',      description: 'Lait corps soyeux karité + coco.',                 price_label: '12 900 FCFA' %}
          {% render 'card-product-demo', handle: 'slim-tea',    title: 'Slim Detox Tea',      category: 'Amincissant', description: 'Infusion drainante 21 jours.',                     price_label: '9 500 FCFA' %}
        {%- endif -%}
      </div>
      <p style="margin-top:24px;color:var(--muted);font-size:12px;font-style:italic;">
        Aperçu démo — importe <code>shopify-products.csv</code> puis lie une collection pour passer en réel.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection en vedette",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Ancre (id)", "default": "produits" },
    { "type": "text", "id": "kicker", "label": "Kicker (petit titre)", "default": "Catalogue" },
    { "type": "text", "id": "heading", "label": "Titre", "default": "Nos rituels du moment" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Nombre de produits", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "url", "id": "view_all_link", "label": "Lien « Tout voir »" }
  ],
  "presets": [{ "name": "Collection en vedette" }]
}
{% endschema %}
