<footer class="site-footer">
  <div class="container">
    <div class="ftr-grid">
      <div>
        <div class="ftr-brand">{{ section.settings.brand_line_1 | default: shop.name }}</div>
        <div class="ftr-sub">{{ section.settings.brand_line_2 }}</div>
        <p>{{ section.settings.about_text }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'link_column' -%}
          <div {{ block.shopify_attributes }}>
            <span class="kicker">{{ block.settings.heading }}</span>
            {%- for link in block.settings.menu.links -%}
              <div><a href="{{ link.url }}">{{ link.title }}</a></div>
            {%- endfor -%}
          </div>
        {%- when 'text_column' -%}
          <div {{ block.shopify_attributes }}>
            <span class="kicker">{{ block.settings.heading }}</span>
            {{ block.settings.content }}
          </div>
        {%- endcase -%}
      {%- endfor -%}

      <div>
        <span class="kicker">Service</span>
        <div class="ftr-contacts">
          {%- if section.settings.whatsapp_phone != blank -%}
            {%- assign wa_phone_clean = section.settings.whatsapp_phone | replace: '+', '' | replace: ' ', '' | replace: '-', '' -%}
            {%- assign wa_msg = section.settings.whatsapp_message | default: 'Bonjour' | url_encode -%}
            <a class="ftr-btn ftr-btn-wa" href="https://wa.me/{{ wa_phone_clean }}?text={{ wa_msg }}" target="_blank" rel="noopener">
              WhatsApp
            </a>
          {%- endif -%}
          {%- if section.settings.snapchat_handle != blank -%}
            <a class="ftr-btn ftr-btn-snap" href="https://www.snapchat.com/add/{{ section.settings.snapchat_handle }}" target="_blank" rel="noopener">
              Snapchat
            </a>
          {%- endif -%}
          <a class="ftr-btn ftr-btn-track" href="{{ section.settings.order_tracking_url | default: '/account/orders' }}">
            Suivi commande
          </a>
        </div>
      </div>
    </div>

    <div class="ftr-bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ section.settings.brand_line_1 | default: shop.name }}</span>
      <span>{{ section.settings.legal }}</span>
    </div>
  </div>
</footer>

<style>
  .ftr-contacts { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
  .ftr-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: var(--r-pill);
    font-size: 13px;
    font-weight: 600;
    background: rgba(255,255,255,.1);
    color: var(--rose-50) !important;
    border: 1px solid rgba(255,255,255,.2);
    transition: background .15s, color .15s, transform .15s;
    text-decoration: none;
    align-self: flex-start;
  }
  .ftr-btn:hover { background: rgba(255,255,255,.2); color: #fff !important; transform: translateY(-1px); }
  .ftr-btn-wa:hover    { background: #25D366; border-color: #25D366; color: #fff !important; }
  .ftr-btn-snap:hover  { background: #FFFC00; border-color: #FFFC00; color: #1a1414 !important; }
  .ftr-btn-track:hover { background: var(--bordeaux); border-color: var(--bordeaux); color: #fff !important; }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_line_1", "label": "Ligne 1", "default": "My body goal" },
    { "type": "text", "id": "brand_line_2", "label": "Ligne 2", "default": "By Kairos.Distribution" },
    { "type": "textarea", "id": "about_text", "label": "À propos", "default": "Beauté, silhouette et confiance. Expédition partout dans le monde." },

    { "type": "header", "content": "Contact rapide" },
    { "type": "text", "id": "whatsapp_phone", "label": "Numéro WhatsApp (avec indicatif)", "info": "Ex. +221770000000. Laisse vide pour masquer le bouton." },
    { "type": "textarea", "id": "whatsapp_message", "label": "Message pré-rempli WhatsApp", "default": "Bonjour Kairos, je souhaite des informations sur vos produits." },
    { "type": "text", "id": "snapchat_handle", "label": "Identifiant Snapchat", "info": "Ex. kairos.distribution. Laisse vide pour masquer le bouton." },
    { "type": "url",  "id": "order_tracking_url", "label": "Lien « Suivi commande »", "default": "/account/orders" },

    { "type": "text", "id": "legal", "label": "Mention bas", "default": "Tous droits réservés" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Colonne liens",
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Boutique" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "text_column",
      "name": "Colonne texte",
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Livraison" },
        { "type": "richtext", "id": "content", "label": "Contenu", "default": "<p>Partout dans le monde</p><p>Expédition 24-72h</p>" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
