{%- assign wa_phone     = section.settings.whatsapp_phone | default: '' -%}
{%- assign wa_message   = section.settings.whatsapp_message | default: 'Bonjour Kairos, je souhaite des informations sur vos produits.' -%}
{%- assign snap_handle  = section.settings.snapchat_handle | default: '' -%}
{%- assign tracking_url = section.settings.order_tracking_url | default: '/account/orders' -%}

{%- capture wa_href -%}
  {%- if wa_phone != blank -%}
    https://wa.me/{{ wa_phone | replace: '+', '' | replace: ' ', '' | replace: '-', '' }}?text={{ wa_message | url_encode }}
  {%- else -%}
    #
  {%- endif -%}
{%- endcapture -%}

{%- capture snap_href -%}
  {%- if snap_handle != blank -%}
    https://www.snapchat.com/add/{{ snap_handle }}
  {%- else -%}
    #
  {%- endif -%}
{%- endcapture -%}

<footer class="site-footer">
  <div class="container">
    <div class="ftr-grid">
      <div>
        <div class="ftr-brand">{{ section.settings.brand_line_1 | default: shop.name }}</div>
        <div class="ftr-sub">{{ section.settings.brand_line_2 }}</div>
        <p>{{ section.settings.about_text }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'link_column' -%}
          <div {{ block.shopify_attributes }}>
            <span class="kicker">{{ block.settings.heading }}</span>
            {%- for link in block.settings.menu.links -%}
              <div><a href="{{ link.url }}">{{ link.title }}</a></div>
            {%- endfor -%}
          </div>
        {%- when 'text_column' -%}
          <div {{ block.shopify_attributes }}>
            <span class="kicker">{{ block.settings.heading }}</span>
            {{ block.settings.content }}
          </div>
        {%- endcase -%}
      {%- endfor -%}

      <div>
        <span class="kicker">Service</span>
        <div class="ftr-contacts">
          {%- if wa_phone != blank -%}
            <a class="ftr-btn ftr-btn-wa" href="{{ wa_href | strip }}" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.5 3.5A11.9 11.9 0 0 0 12 0C5.4 0 0 5.4 0 12c0 2.1.6 4.2 1.6 6L0 24l6.2-1.6c1.8 1 3.8 1.5 5.8 1.5 6.6 0 12-5.4 12-12 0-3.2-1.2-6.2-3.5-8.4zM12 21.8c-1.8 0-3.6-.5-5.2-1.4l-.4-.2-3.7 1 1-3.6-.2-.4A9.8 9.8 0 0 1 2.2 12C2.2 6.6 6.6 2.2 12 2.2c2.6 0 5.1 1 7 2.9 1.9 1.9 2.9 4.4 2.9 7 0 5.4-4.4 9.7-9.9 9.7zm5.4-7.3c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.3-.8.9-1 1.1-.2.2-.4.2-.6.1-1.9-.9-3.1-1.7-4.4-3.8-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5-.1-.1-.7-1.6-.9-2.1-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.5 0 1.5 1.1 2.9 1.3 3.1.1.2 2.2 3.3 5.3 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3z"/>
              </svg>
              WhatsApp
            </a>
          {%- endif -%}
          {%- if snap_handle != blank -%}
            <a class="ftr-btn ftr-btn-snap" href="{{ snap_href | strip }}" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12.2 1.5c3.6 0 6.2 2.3 6.2 6.2v1.8c.1.1.3.1.5.2.3.1.7.2 1.1.2.6 0 1.1-.2 1.6-.4.2-.1.4-.2.6-.2.4 0 .8.2.9.6.1.4-.1.8-.5 1-.2.1-.5.2-.8.3-.6.3-1.4.6-1.5 1-.1.2 0 .5.3.9.2.5 1.5 2.6 3.7 2.9.2 0 .4.2.4.5s-.2.5-.4.5c-.1 0-.2.1-.3.1-.5.1-.9.2-1.2.6-.2.3-.2.8-.1 1.4.1.3 0 .6-.3.7-.3.1-.7 0-1.4-.2-.3-.1-.6-.1-1-.1-.5 0-1 .1-1.6.3-.6.2-1.3.7-2.1 1.2-1 .7-2.1 1.4-3.6 1.4h-.2c-1.5 0-2.6-.7-3.6-1.4-.8-.5-1.5-1-2.1-1.2-.6-.2-1.1-.3-1.6-.3-.4 0-.7 0-1 .1-.7.2-1.1.3-1.4.2-.3-.1-.4-.4-.3-.7.1-.6.1-1.1-.1-1.4-.3-.4-.7-.5-1.2-.6-.1 0-.2-.1-.3-.1-.3 0-.4-.2-.4-.5s.2-.5.4-.5c2.2-.3 3.5-2.4 3.7-2.9.3-.5.4-.8.3-.9-.1-.4-.9-.7-1.5-1-.3-.1-.6-.2-.8-.3-.4-.2-.6-.6-.5-1 .2-.4.5-.6.9-.6.2 0 .4.1.6.2.5.2 1 .4 1.6.4.4 0 .8-.1 1.1-.2.2-.1.4-.1.5-.2V7.7c0-3.9 2.6-6.2 6.2-6.2z"/>
              </svg>
              Snapchat
            </a>
          {%- endif -%}
          <a class="ftr-btn ftr-btn-track" href="{{ tracking_url }}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 7h11v10H3zM14 10h4l3 3v4h-7z"/>
              <circle cx="7" cy="18" r="1.5" fill="currentColor"/>
              <circle cx="17" cy="18" r="1.5" fill="currentColor"/>
            </svg>
            Suivi commande
          </a>
        </div>
      </div>
    </div>

    <div class="ftr-bottom">
      <span>© {{ 'now' | date: '%Y' }} {{ section.settings.brand_line_1 | default: shop.name }}</span>
      <span>{{ section.settings.legal }}</span>
    </div>
  </div>
</footer>

<style>
  .ftr-contacts { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
  .ftr-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: var(--r-pill);
    font-size: 13px;
    font-weight: 600;
    background: rgba(255,255,255,.1);
    color: var(--rose-50) !important;
    border: 1px solid rgba(255,255,255,.2);
    transition: background .15s, color .15s, transform .15s;
    text-decoration: none;
    align-self: flex-start;
  }
  .ftr-btn:hover { background: rgba(255,255,255,.2); color: #fff !important; transform: translateY(-1px); }
  .ftr-btn-wa:hover    { background: #25D366; border-color: #25D366; color: #fff !important; }
  .ftr-btn-snap:hover  { background: #FFFC00; border-color: #FFFC00; color: #1a1414 !important; }
  .ftr-btn-track:hover { background: var(--bordeaux); border-color: var(--bordeaux); color: #fff !important; }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_line_1", "label": "Ligne 1", "default": "My body goal" },
    { "type": "text", "id": "brand_line_2", "label": "Ligne 2", "default": "By Kairos.Distribution" },
    { "type": "textarea", "id": "about_text", "label": "À propos", "default": "Beauté, silhouette et confiance. Expédition partout dans le monde." },

    { "type": "header", "content": "Contact rapide" },
    { "type": "text", "id": "whatsapp_phone", "label": "Numéro WhatsApp (avec indicatif)", "info": "Ex. +221770000000. Laisse vide pour masquer le bouton.", "default": "" },
    { "type": "textarea", "id": "whatsapp_message", "label": "Message pré-rempli WhatsApp", "default": "Bonjour Kairos, je souhaite des informations sur vos produits." },
    { "type": "text", "id": "snapchat_handle", "label": "Identifiant Snapchat", "info": "Ex. kairos.distribution. Laisse vide pour masquer le bouton.", "default": "" },
    { "type": "url",  "id": "order_tracking_url", "label": "Lien « Suivi commande »", "default": "/account/orders", "info": "URL ou page de suivi (/pages/suivi)." },

    { "type": "text", "id": "legal", "label": "Mention bas", "default": "Tous droits réservés" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Colonne liens",
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Boutique" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "text_column",
      "name": "Colonne texte",
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Livraison" },
        { "type": "richtext", "id": "content", "label": "Contenu", "default": "<p>Partout dans le monde</p><p>Expédition 24-72h</p>" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
