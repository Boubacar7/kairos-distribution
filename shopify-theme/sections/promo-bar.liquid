{%- if section.settings.enabled -%}
<div class="promo-bar"
     style="background:{{ section.settings.bg | default: '#6d1e3a' }};
            color:{{ section.settings.fg | default: '#ffffff' }};">
  <div class="promo-track" data-promo-track>
    {%- for block in section.blocks -%}
      <div class="promo-msg" {{ block.shopify_attributes }}>
        {%- if block.settings.url != blank -%}
          <a href="{{ block.settings.url }}" style="color:inherit;text-decoration:none;">{{ block.settings.text }}</a>
        {%- else -%}
          {{ block.settings.text }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .promo-bar { position: relative; overflow: hidden; padding: 8px 16px; font-size: 12px; font-weight: 500; letter-spacing: 0.04em; text-align: center; }
  .promo-track { position: relative; min-height: 1.3em; }
  .promo-msg { position: absolute; inset: 0; opacity: 0; transition: opacity .4s ease; }
  .promo-msg.is-active { opacity: 1; position: relative; }
</style>

<script>
  (function() {
    var track = document.querySelector('[data-promo-track]');
    if (!track) return;
    var msgs = track.querySelectorAll('.promo-msg');
    if (msgs.length === 0) return;
    var i = 0;
    msgs[0].classList.add('is-active');
    if (msgs.length === 1) return;
    setInterval(function() {
      msgs[i].classList.remove('is-active');
      i = (i + 1) % msgs.length;
      msgs[i].classList.add('is-active');
    }, {{ section.settings.rotate_seconds | default: 5 | times: 1000 }});
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Bandeau promo",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Activer le bandeau", "default": true },
    { "type": "color", "id": "bg", "label": "Fond", "default": "#6d1e3a" },
    { "type": "color", "id": "fg", "label": "Texte", "default": "#ffffff" },
    { "type": "range", "id": "rotate_seconds", "label": "Rotation (secondes)", "min": 3, "max": 12, "step": 1, "default": 5 }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Texte", "default": "Livraison offerte dès 30 000 FCFA" },
        { "type": "url",  "id": "url",  "label": "Lien (optionnel)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Bandeau promo",
      "blocks": [
        { "type": "message", "settings": { "text": "Livraison offerte dès 30 000 FCFA" } },
        { "type": "message", "settings": { "text": "Paiement à la livraison · CB · Wave · Mobile Money" } },
        { "type": "message", "settings": { "text": "Garantie satisfait ou remboursé sous 7 jours" } }
      ]
    }
  ]
}
{% endschema %}
