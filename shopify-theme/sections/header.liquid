{%- assign is_home = false -%}
{%- if template == 'index' -%}
  {%- assign is_home = true -%}
{%- endif -%}

<header class="site-header{% if is_home %} is-home is-transparent{% else %} is-opaque{% endif %}" data-is-home="{{ is_home }}">
  <div class="nav-inner">
    {%- comment -%}
      Sur la home (tant que la nav est transparente), on masque le bloc marque du header :
      la bannière contient déjà les 3 lignes en haut à gauche, alignées sur l'axe de la nav.
      Dès qu'on scrolle (nav opaque), le bloc marque réapparaît.
    {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="brand-wrap" style="display:flex;flex-direction:column;">
      <span class="nav-brand">{{ section.settings.brand_line_1 | default: shop.name }}</span>
      <span class="nav-sub">{{ section.settings.brand_line_2 }}</span>
    </a>

    <nav class="nav-links">
      {%- comment -%}
        Priorité 1 : liens saisis dans le Customizer (section settings)
        Priorité 2 : menu Shopify sélectionné (link_list)
      {%- endcomment -%}
      {%- assign has_custom_links = false -%}
      {%- if section.settings.link_1_label != blank or section.settings.link_2_label != blank or section.settings.link_3_label != blank or section.settings.link_4_label != blank or section.settings.link_5_label != blank -%}
        {%- assign has_custom_links = true -%}
      {%- endif -%}

      {%- if has_custom_links -%}
        {%- for i in (1..5) -%}
          {%- assign label_key = 'link_' | append: i | append: '_label' -%}
          {%- assign url_key   = 'link_' | append: i | append: '_url' -%}
          {%- assign label     = section.settings[label_key] -%}
          {%- assign url       = section.settings[url_key] -%}
          {%- if label != blank -%}
            {%- assign url_value = url | default: '#' -%}
            <a href="{{ url_value }}"
               class="nav-link"
               {% if url_value contains '#' %}data-anchor="{{ url_value | split: '#' | last }}"{% endif %}>
              {{ label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for link in section.settings.menu.links -%}
          <a
            href="{{ link.url }}"
            class="nav-link{% if link.active %} active{% endif %}"
            {% if link.url contains '#' %}data-anchor="{{ link.url | split: '#' | last }}"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <div class="nav-right">
      {%- assign rates = '{' -%}
      {%- capture rates -%}
        {"FCFA":1,"EUR":{{ settings.currency_rate_eur | default: 656 }},"USD":{{ settings.currency_rate_usd | default: 610 }},"CAD":{{ settings.currency_rate_cad | default: 445 }}}
      {%- endcapture -%}
      <div class="cur-seg" data-currency-switcher data-rates="{{ rates | strip }}" data-default="{{ settings.currency_default | default: 'FCFA' }}">
        {%- if settings.currency_show_fcfa -%}<button type="button" class="cur-btn" data-currency="FCFA">FCFA</button>{%- endif -%}
        {%- if settings.currency_show_eur  -%}<button type="button" class="cur-btn" data-currency="EUR">EUR</button>{%- endif -%}
        {%- if settings.currency_show_usd  -%}<button type="button" class="cur-btn" data-currency="USD">USD</button>{%- endif -%}
        {%- if settings.currency_show_cad  -%}<button type="button" class="cur-btn" data-currency="CAD">CAD</button>{%- endif -%}
      </div>

      {%- if localization.available_languages.size > 1 -%}
        {%- form 'localization', id: 'header-language-form' -%}
          <div class="lang-seg" role="group" aria-label="Langue">
            {%- for lang in localization.available_languages -%}
              <button type="submit" name="locale_code" value="{{ lang.iso_code }}"
                      class="lang-btn{% if lang.iso_code == localization.language.iso_code %} on{% endif %}"
                      aria-current="{% if lang.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}">
                {{ lang.iso_code | upcase }}
              </button>
            {%- endfor -%}
          </div>
        {%- endform -%}
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="nav-cart" aria-label="Panier">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 4h2l2.5 12h11L21 7H6"/>
          <circle cx="9" cy="20" r="1.3"/>
          <circle cx="17" cy="20" r="1.3"/>
        </svg>
        <span class="cart-label">{{ 'sections.header.cart' | t }}</span>
        {%- if cart.item_count > 0 -%}
          <span class="nav-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <button type="button" class="nav-mobile-btn" data-mobile-menu aria-label="Menu" aria-expanded="false">
        <svg class="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" style="display:none;"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
  </div>

  <div class="nav-mobile-panel" data-mobile-panel hidden>
    {%- if has_custom_links -%}
      {%- for i in (1..5) -%}
        {%- assign label_key = 'link_' | append: i | append: '_label' -%}
        {%- assign url_key   = 'link_' | append: i | append: '_url' -%}
        {%- assign label     = section.settings[label_key] -%}
        {%- assign url       = section.settings[url_key] -%}
        {%- if label != blank -%}
          {%- assign url_value = url | default: '#' -%}
          <a href="{{ url_value }}"
             class="nav-mobile-link"
             {% if url_value contains '#' %}data-anchor="{{ url_value | split: '#' | last }}"{% endif %}>
            {{ label }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}"
           class="nav-mobile-link{% if link.active %} active{% endif %}"
           {% if link.url contains '#' %}data-anchor="{{ link.url | split: '#' | last }}"{% endif %}
        >{{ link.title }}</a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</header>

<style>
  /* Sur la home tant qu'on est en nav transparente, le bloc marque s'efface
     pour laisser la place à la pile de 3 lignes du hero. */
  .site-header.is-home.is-transparent .brand-wrap {
    opacity: 0;
    pointer-events: none;
  }

  /* Currency switcher */
  .cur-seg {
    display: flex; gap: 3px; padding: 3px;
    border-radius: var(--r-pill);
    background: rgba(255,255,255,.15);
    backdrop-filter: blur(4px);
  }
  .site-header.is-opaque .cur-seg { background: var(--cream-2); }
  .cur-btn {
    padding: 5px 9px; font-size: 10px; font-weight: 700;
    border-radius: var(--r-pill);
    color: #fff; cursor: pointer;
    transition: background .15s, color .15s;
  }
  .site-header.is-opaque .cur-btn { color: var(--ink-2); }
  .cur-btn.on { background: #fff; color: var(--bordeaux); }
  .site-header.is-opaque .cur-btn.on { background: var(--bordeaux); color: #fff; }

  /* Language switcher */
  .lang-seg {
    display: flex; gap: 3px; padding: 3px;
    border-radius: var(--r-pill);
    background: rgba(255,255,255,.12);
  }
  .site-header.is-opaque .lang-seg { background: var(--cream-2); }
  .lang-btn {
    padding: 5px 9px; font-size: 10px; font-weight: 700;
    border-radius: var(--r-pill);
    color: #fff; cursor: pointer;
    border: 0; background: none;
  }
  .site-header.is-opaque .lang-btn { color: var(--ink-2); }
  .lang-btn.on { background: #fff; color: var(--bordeaux); }
  .site-header.is-opaque .lang-btn.on { background: var(--bordeaux); color: #fff; }

  @media (max-width: 700px) {
    .cur-seg, .lang-seg { display: none; }
  }
  .nav-mobile-btn {
    display: none;
    padding: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, .4);
    background: rgba(0, 0, 0, .3);
    color: #fff;
    backdrop-filter: blur(4px);
  }
  .site-header.is-opaque .nav-mobile-btn {
    border-color: var(--line-2);
    background: var(--cream-2);
    color: var(--ink);
  }
  .nav-mobile-panel {
    background: #fff;
    border-top: 1px solid var(--line);
    padding: 12px 16px;
    box-shadow: 0 8px 20px rgba(0,0,0,.08);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height .3s, opacity .3s;
  }
  .nav-mobile-panel[hidden] { max-height: 0; opacity: 0; }
  .nav-mobile-panel:not([hidden]) { max-height: 400px; opacity: 1; display: block !important; }
  .nav-mobile-link {
    display: block;
    padding: 12px 0;
    font-size: 15px;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }
  .nav-mobile-link:last-child { border-bottom: 0; }
  .nav-mobile-link.active { color: var(--bordeaux); font-weight: 600; }
  .cart-label { display: inline; }
  @media (max-width: 860px) {
    .nav-mobile-btn { display: flex; align-items: center; justify-content: center; }
    .nav-cart { padding: 9px 12px; }
    .cart-label { display: none; }
  }
</style>

<script>
  (function() {
    var header = document.querySelector('.site-header');
    if (!header) return;

    var btn = header.querySelector('[data-mobile-menu]');
    var panel = header.querySelector('[data-mobile-panel]');
    if (btn && panel) {
      btn.addEventListener('click', function() {
        var isHidden = panel.hasAttribute('hidden');
        if (isHidden) {
          panel.removeAttribute('hidden');
          btn.setAttribute('aria-expanded', 'true');
          btn.querySelector('.icon-open').style.display = 'none';
          btn.querySelector('.icon-close').style.display = 'block';
        } else {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
          btn.querySelector('.icon-open').style.display = 'block';
          btn.querySelector('.icon-close').style.display = 'none';
        }
      });
      panel.querySelectorAll('.nav-mobile-link').forEach(function(a) {
        a.addEventListener('click', function() {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
          btn.querySelector('.icon-open').style.display = 'block';
          btn.querySelector('.icon-close').style.display = 'none';
        });
      });
    }

    var isHome = header.getAttribute('data-is-home') === 'true';
    if (!isHome) return;

    var anchorLinks = header.querySelectorAll('[data-anchor]');
    if (!anchorLinks.length) return;

    var ids = [];
    anchorLinks.forEach(function(a) {
      var id = a.getAttribute('data-anchor');
      if (id && ids.indexOf(id) === -1) ids.push(id);
    });
    var sections = ids
      .map(function(id) { return document.getElementById(id); })
      .filter(function(el) { return !!el; });
    if (!sections.length) return;

    function updateActive(activeId) {
      anchorLinks.forEach(function(a) {
        if (a.getAttribute('data-anchor') === activeId) a.classList.add('active');
        else a.classList.remove('active');
      });
    }

    var observer = new IntersectionObserver(function(entries) {
      var visible = entries.filter(function(e) { return e.isIntersecting; });
      visible.sort(function(a, b) { return b.intersectionRatio - a.intersectionRatio; });
      if (visible[0]) updateActive(visible[0].target.id);
    }, { rootMargin: '-40% 0px -40% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });

    sections.forEach(function(el) { observer.observe(el); });
  })();

  // Multi-currency switcher (FCFA / EUR / USD / CAD)
  (function() {
    var segment = document.querySelector('[data-currency-switcher]');
    // Les taux sont lus depuis le segment si présent, sinon on se replie
    // sur les valeurs par défaut — ainsi la conversion marche même si le
    // switcher est masqué (mobile < 700px, toutes cases décochées, etc.).
    var rates = {
      FCFA: 1,
      EUR: {{ settings.currency_rate_eur | default: 656 }},
      USD: {{ settings.currency_rate_usd | default: 610 }},
      CAD: {{ settings.currency_rate_cad | default: 445 }}
    };
    if (segment) {
      try { rates = JSON.parse(segment.getAttribute('data-rates')) || rates; } catch(e) {}
    }
    var defaultCur = (segment && segment.getAttribute('data-default')) || '{{ settings.currency_default | default: "FCFA" }}';
    var stored = null;
    try { stored = localStorage.getItem('kairos_currency'); } catch(e) {}
    var active = (stored && rates[stored]) ? stored : defaultCur;

    function fmt(fcfa, cur) {
      var rate = rates[cur] || 1;
      var value = fcfa / rate;
      if (cur === 'FCFA') {
        return Math.round(value).toLocaleString('fr-FR').replace(/,/g, ' ') + ' FCFA';
      }
      if (cur === 'EUR') {
        return value.toFixed(2).replace('.', ',') + ' €';
      }
      if (cur === 'USD') {
        return '$' + value.toFixed(2);
      }
      if (cur === 'CAD') {
        return 'CA$' + value.toFixed(2);
      }
      return value.toFixed(2) + ' ' + cur;
    }

    function applyCurrency(cur) {
      if (!rates[cur]) cur = defaultCur;
      active = cur;
      try { localStorage.setItem('kairos_currency', cur); } catch(e) {}
      if (segment) {
        segment.querySelectorAll('.cur-btn').forEach(function(b) {
          if (b.getAttribute('data-currency') === cur) b.classList.add('on');
          else b.classList.remove('on');
        });
      }
      document.querySelectorAll('[data-price-fcfa]').forEach(function(el) {
        var base = parseInt(el.getAttribute('data-price-fcfa'), 10);
        if (!isNaN(base)) el.textContent = fmt(base, cur);
      });
      document.querySelectorAll('[data-compare-fcfa]').forEach(function(el) {
        var base = parseInt(el.getAttribute('data-compare-fcfa'), 10);
        if (!isNaN(base)) el.textContent = fmt(base, cur);
      });
    }

    // Expose global pour que les sections (catalogue éditable, modal produit)
    // puissent déclencher une conversion après rendu dynamique.
    window.kairosApplyCurrency = applyCurrency;
    window.kairosGetCurrency  = function() { return active; };

    if (segment) {
      segment.querySelectorAll('.cur-btn').forEach(function(b) {
        b.addEventListener('click', function() {
          applyCurrency(b.getAttribute('data-currency'));
        });
      });
    }
    applyCurrency(active);

    // Re-trigger automatique quand Shopify Customizer recharge une section
    document.addEventListener('shopify:section:load', applyCurrency.bind(null, active));
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "brand_line_1", "label": "Ligne 1 (nom marque)", "default": "My body goal" },
    { "type": "text", "id": "brand_line_2", "label": "Ligne 2 (signature)", "default": "By Kairos.Distribution" },

    { "type": "header", "content": "Menu (5 liens max)" },
    { "type": "paragraph", "content": "Remplis les paires ci-dessous. Laisse vides pour utiliser le menu Shopify ci-dessous à la place. Les liens avec # (ex. /#produits) déclenchent le scroll-spy automatiquement." },

    { "type": "text", "id": "link_1_label", "label": "Lien 1 — libellé", "default": "Accueil" },
    { "type": "url",  "id": "link_1_url",   "label": "Lien 1 — URL",     "default": "/" },

    { "type": "text", "id": "link_2_label", "label": "Lien 2 — libellé", "default": "Produits" },
    { "type": "url",  "id": "link_2_url",   "label": "Lien 2 — URL",     "default": "/#produits" },

    { "type": "text", "id": "link_3_label", "label": "Lien 3 — libellé", "default": "Avis clients" },
    { "type": "url",  "id": "link_3_url",   "label": "Lien 3 — URL",     "default": "/#avis" },

    { "type": "text", "id": "link_4_label", "label": "Lien 4 — libellé", "default": "Retours clients" },
    { "type": "url",  "id": "link_4_url",   "label": "Lien 4 — URL",     "default": "/#retours" },

    { "type": "text", "id": "link_5_label", "label": "Lien 5 — libellé", "default": "" },
    { "type": "url",  "id": "link_5_url",   "label": "Lien 5 — URL",     "default": "" },

    { "type": "header", "content": "Menu Shopify (fallback)" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu", "info": "Utilisé si aucun libellé n'est rempli ci-dessus." }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
