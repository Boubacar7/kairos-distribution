{%- assign is_home = false -%}
{%- if template == 'index' -%}
  {%- assign is_home = true -%}
{%- endif -%}

<header class="site-header{% if is_home %} is-home is-transparent{% else %} is-opaque{% endif %}">
  <div class="nav-inner">
    <a href="{{ routes.root_url }}" class="brand-wrap" style="display:flex;flex-direction:column;">
      <span class="nav-brand">{{ section.settings.brand_line_1 | default: shop.name }}</span>
      <span class="nav-sub">{{ section.settings.brand_line_2 }}</span>
    </a>

    <nav class="nav-links">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="nav-right">
      <a href="{{ routes.cart_url }}" class="nav-cart">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 4h2l2.5 12h11L21 7H6"/>
          <circle cx="9" cy="20" r="1.3"/>
          <circle cx="17" cy="20" r="1.3"/>
        </svg>
        {{ 'sections.header.cart' | t }}
        {%- if cart.item_count > 0 -%}
          <span class="nav-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <button type="button" data-mobile-menu aria-label="Menu" style="display:none;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,.3);color:#fff;background:rgba(255,255,255,.15);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <div data-mobile-panel hidden style="background:#fff;border-top:1px solid var(--line);padding:12px 16px;">
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" style="display:block;padding:12px 0;border-bottom:1px solid var(--line);font-size:15px;color:var(--ink);{% if link.active %}color:var(--bordeaux);font-weight:600;{% endif %}">
        {{ link.title }}
      </a>
    {%- endfor -%}
  </div>
</header>

<style>
@media (max-width: 860px) {
  [data-mobile-menu] { display: flex !important; align-items: center; justify-content: center; }
}
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "brand_line_1", "label": "Ligne 1 (nom marque)", "default": "My body goal" },
    { "type": "text", "id": "brand_line_2", "label": "Ligne 2 (signature)", "default": "By Kairos.Distribution" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
