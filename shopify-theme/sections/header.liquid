{%- assign is_home = false -%}
{%- if template == 'index' -%}
  {%- assign is_home = true -%}
{%- endif -%}

<header class="site-header{% if is_home %} is-home is-transparent{% else %} is-opaque{% endif %}" data-is-home="{{ is_home }}">
  <div class="nav-inner">
    {%- comment -%}
      Sur la home (tant que la nav est transparente), on masque le bloc marque du header :
      la bannière contient déjà les 3 lignes en haut à gauche, alignées sur l'axe de la nav.
      Dès qu'on scrolle (nav opaque), le bloc marque réapparaît.
    {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="brand-wrap" style="display:flex;flex-direction:column;">
      <span class="nav-brand">{{ section.settings.brand_line_1 | default: shop.name }}</span>
      <span class="nav-sub">{{ section.settings.brand_line_2 }}</span>
    </a>

    <nav class="nav-links">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="nav-link{% if link.active %} active{% endif %}"
          {% if link.url contains '#' %}data-anchor="{{ link.url | split: '#' | last }}"{% endif %}
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="nav-right">
      <a href="{{ routes.cart_url }}" class="nav-cart" aria-label="Panier">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 4h2l2.5 12h11L21 7H6"/>
          <circle cx="9" cy="20" r="1.3"/>
          <circle cx="17" cy="20" r="1.3"/>
        </svg>
        <span class="cart-label">{{ 'sections.header.cart' | t }}</span>
        {%- if cart.item_count > 0 -%}
          <span class="nav-badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <button type="button" class="nav-mobile-btn" data-mobile-menu aria-label="Menu" aria-expanded="false">
        <svg class="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg class="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" style="display:none;"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
  </div>

  <div class="nav-mobile-panel" data-mobile-panel hidden>
    {%- for link in section.settings.menu.links -%}
      <a
        href="{{ link.url }}"
        class="nav-mobile-link{% if link.active %} active{% endif %}"
        {% if link.url contains '#' %}data-anchor="{{ link.url | split: '#' | last }}"{% endif %}
      >{{ link.title }}</a>
    {%- endfor -%}
  </div>
</header>

<style>
  /* Sur la home tant qu'on est en nav transparente, le bloc marque s'efface
     pour laisser la place à la pile de 3 lignes du hero. */
  .site-header.is-home.is-transparent .brand-wrap {
    opacity: 0;
    pointer-events: none;
  }
  .nav-mobile-btn {
    display: none;
    padding: 8px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, .4);
    background: rgba(0, 0, 0, .3);
    color: #fff;
    backdrop-filter: blur(4px);
  }
  .site-header.is-opaque .nav-mobile-btn {
    border-color: var(--line-2);
    background: var(--cream-2);
    color: var(--ink);
  }
  .nav-mobile-panel {
    background: #fff;
    border-top: 1px solid var(--line);
    padding: 12px 16px;
    box-shadow: 0 8px 20px rgba(0,0,0,.08);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height .3s, opacity .3s;
  }
  .nav-mobile-panel[hidden] { max-height: 0; opacity: 0; }
  .nav-mobile-panel:not([hidden]) { max-height: 400px; opacity: 1; display: block !important; }
  .nav-mobile-link {
    display: block;
    padding: 12px 0;
    font-size: 15px;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }
  .nav-mobile-link:last-child { border-bottom: 0; }
  .nav-mobile-link.active { color: var(--bordeaux); font-weight: 600; }
  .cart-label { display: inline; }
  @media (max-width: 860px) {
    .nav-mobile-btn { display: flex; align-items: center; justify-content: center; }
    .nav-cart { padding: 9px 12px; }
    .cart-label { display: none; }
  }
</style>

<script>
  (function() {
    var header = document.querySelector('.site-header');
    if (!header) return;

    var btn = header.querySelector('[data-mobile-menu]');
    var panel = header.querySelector('[data-mobile-panel]');
    if (btn && panel) {
      btn.addEventListener('click', function() {
        var isHidden = panel.hasAttribute('hidden');
        if (isHidden) {
          panel.removeAttribute('hidden');
          btn.setAttribute('aria-expanded', 'true');
          btn.querySelector('.icon-open').style.display = 'none';
          btn.querySelector('.icon-close').style.display = 'block';
        } else {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
          btn.querySelector('.icon-open').style.display = 'block';
          btn.querySelector('.icon-close').style.display = 'none';
        }
      });
      panel.querySelectorAll('.nav-mobile-link').forEach(function(a) {
        a.addEventListener('click', function() {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
          btn.querySelector('.icon-open').style.display = 'block';
          btn.querySelector('.icon-close').style.display = 'none';
        });
      });
    }

    var isHome = header.getAttribute('data-is-home') === 'true';
    if (!isHome) return;

    var anchorLinks = header.querySelectorAll('[data-anchor]');
    if (!anchorLinks.length) return;

    var ids = [];
    anchorLinks.forEach(function(a) {
      var id = a.getAttribute('data-anchor');
      if (id && ids.indexOf(id) === -1) ids.push(id);
    });
    var sections = ids
      .map(function(id) { return document.getElementById(id); })
      .filter(function(el) { return !!el; });
    if (!sections.length) return;

    function updateActive(activeId) {
      anchorLinks.forEach(function(a) {
        if (a.getAttribute('data-anchor') === activeId) a.classList.add('active');
        else a.classList.remove('active');
      });
    }

    var observer = new IntersectionObserver(function(entries) {
      var visible = entries.filter(function(e) { return e.isIntersecting; });
      visible.sort(function(a, b) { return b.intersectionRatio - a.intersectionRatio; });
      if (visible[0]) updateActive(visible[0].target.id);
    }, { rootMargin: '-40% 0px -40% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });

    sections.forEach(function(el) { observer.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "brand_line_1", "label": "Ligne 1 (nom marque)", "default": "My body goal" },
    { "type": "text", "id": "brand_line_2", "label": "Ligne 2 (signature)", "default": "By Kairos.Distribution" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
