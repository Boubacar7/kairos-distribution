generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum ProductStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  NEW
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ORANGE_MONEY
  WAVE
  MOOV_MONEY
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  activities   Activity[]
}

model Product {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String?
  category    String
  price       Int
  promo       Int            @default(0)
  stock       Int            @default(0)
  image       String?
  status      ProductStatus  @default(PUBLISHED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  variants    Variant[]
  items       OrderItem[]
  reviews     Review[]

  @@index([category])
  @@index([status])
}

model Variant {
  id          String   @id @default(cuid())
  productId   String
  name        String
  attributes  Json?
  priceDelta  Int      @default(0)
  stock       Int      @default(0)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  items       OrderItem[]

  @@index([productId])
}

model Order {
  id             String         @id
  userId         String?
  trackingNumber String         @unique
  status         OrderStatus    @default(NEW)
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus  @default(PENDING)
  subtotal       Int
  discount       Int            @default(0)
  delivery       Int            @default(0)
  total          Int
  couponCode     String?
  zoneId         String?
  notes          String?
  customerFirst  String
  customerLast   String
  customerPhone  String
  customerEmail  String?
  customerCity   String
  customerCountry String?
  customerAddress String
  history        Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User?          @relation(fields: [userId], references: [id])
  items          OrderItem[]

  @@index([status])
  @@index([customerPhone])
  @@index([customerEmail])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  variantId  String?
  name       String
  qty        Int
  unitPrice  Int
  lineTotal  Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  variant    Variant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model Review {
  id         String        @id @default(cuid())
  productId  String
  name       String
  contact    String
  rating     Int
  text       String
  photo      String?
  status     ReviewStatus  @default(PENDING)
  createdAt  DateTime      @default(now())
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
}

model Coupon {
  id         String      @id @default(cuid())
  code       String      @unique
  type       CouponType
  value      Int
  minAmount  Int         @default(0)
  maxUses    Int?
  used       Int         @default(0)
  expiresAt  DateTime?
  createdAt  DateTime    @default(now())
}

model Zone {
  id        String   @id @default(cuid())
  name      String
  fee       Int
  createdAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model LoyaltyAccount {
  id        String   @id @default(cuid())
  target    String   @unique
  points    Int      @default(0)
  history   Json?
  updatedAt DateTime @updatedAt
}

model Setting {
  key   String @id
  value Json
}
